nextflow_process {

    name "Test Process GATK4_CHECKREFERENCECOMPATIBILITY"
    script "../main.nf"
    process "GATK4_CHECKREFERENCECOMPATIBILITY"

    tag "modules"
    tag "modules_nfcore"
    tag "gatk4"
    tag "gatk4/checkreferencecompatibility"

    test("sarscov2 - vcf") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test_vcf' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz.tbi', checkIfExists: true)
                ]
                input[1] = [
                    [ id:'sarscov2_refcomp' ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.fai', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.dict', checkIfExists: true) ]
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sarscov2 - vcf - no index") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test_vcf_noindex' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf', checkIfExists: true),
                    []
                ]
                input[1] = [
                    [ id:'sarscov2_refcomp' ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.fai', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.dict', checkIfExists: true) ]
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert path(process.out.tsv[0][1]).readLines()[2].contains("\tCOMPATIBLE\t") }
            )
        }
    }

    test("sarscov2 - bam") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test_bam' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam.bai', checkIfExists: true)
                ]
                input[1] = [
                    [ id:'sarscov2_refcomp' ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.fai', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.dict', checkIfExists: true) ]
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sarscov2 - bam - no index") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test_bam_noindex' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    []
                ]
                input[1] = [
                    [ id:'sarscov2_refcomp' ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.fai', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.dict', checkIfExists: true) ]
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert path(process.out.tsv[0][1]).readLines()[2].contains("\tCOMPATIBLE\t") }
            )
        }
    }

    test("homo_sapiens - cram") {

        config "./with_reference.config"

        when {
            process {
                """
                input[0] = [
                    [ id:'test_cram' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram.crai', checkIfExists: true)
                ]
                input[1] = [
                    [ id:'human_refcomp' ],
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true) ]
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sarscov2 - vcf - incompatible reference") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test_vcf_incompatible' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf', checkIfExists: true),
                    []
                ]
                input[1] = [
                    [ id:'mixed_refcomp' ],
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true) ]
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert path(process.out.tsv[0][1]).readLines()[2].contains("\tNOT_COMPATIBLE\t") }
            )
        }
    }

    test("sarscov2 - vcf - many references") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test_vcf_manyref' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf', checkIfExists: true),
                    []
                ]
                input[1] = [
                    [ id:'many_refcomp' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                    ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.fai', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true)
                    ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.dict', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true)
                    ]
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert path(process.out.tsv[0][1]).readLines().size() == 4 },
                { assert path(process.out.tsv[0][1]).readLines().count { it.contains("\tCOMPATIBLE\t") } == 1 },
                { assert path(process.out.tsv[0][1]).readLines().count { it.contains("\tNOT_COMPATIBLE\t") } == 1 }
            )
        }
    }

    test("stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test_stub' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz.tbi', checkIfExists: true)
                ]
                input[1] = [
                    [ id:'sarscov2_refcomp' ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.fai', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.dict', checkIfExists: true) ]
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }
}
